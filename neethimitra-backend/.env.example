# NeethiMitra AI Backend — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# Lines marked NOTE-MANUAL require you to sign up at an external service.

# ── Sarvam AI ─────────────────────────────────────────────────────────────────
# NOTE-MANUAL: https://dashboard.sarvam.ai → API Keys
SARVAM_API_KEY=your_sarvam_api_key_here

# ── Google OAuth ──────────────────────────────────────────────────────────────
# NOTE-MANUAL: https://console.cloud.google.com → APIs & Services → Credentials
#              Create an OAuth 2.0 Client ID (Web Application type)
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com

# ── JWT Security ──────────────────────────────────────────────────────────────
# Generate your own: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_random_32_char_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
GUEST_ACCESS_TOKEN_EXPIRE_MINUTES=1440
GUEST_QUERY_LIMIT=3

# ── Database ──────────────────────────────────────────────────────────────────
# Development (SQLite — no setup needed):
DATABASE_URL=sqlite:///./neethimitra.db
# Production (Render PostgreSQL — NOTE-MANUAL: copy Internal URL from Render dashboard):
# DATABASE_URL=postgresql://neethimitra:password@dpg-xxxx-a/neethimitra

# ── Server ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Add your Render URL here for production CORS:
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:8082,http://localhost:3000,http://localhost:19006
MAX_UPLOAD_SIZE_MB=10
